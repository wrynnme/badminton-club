# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.agents
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-lock.yaml
yarn.lock

# playwright-cli artifacts (snapshots, console logs)
.playwright-cli/
/*.yaml

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
.claude
.vscode
supabase/.temp/

# codex (tooling-local config — mirrors .claude / .agents)
/.codex

# playwright-mcp smoke artifacts (snapshots / console logs)
.playwright-mcp/

# @playwright/test E2E suite — auth state holds a minted session cookie; reports are run artifacts
/e2e/.auth/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

*storybook.log
storybook-static
