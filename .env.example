# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login (https://developers.line.biz/console/) — channel type: LINE Login
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback

# LINE LIFF — auto-login inside the LINE in-app browser (LINE Browser).
# Create a LIFF app UNDER the same LINE Login channel as LINE_CHANNEL_ID above
# (Console → that Login channel → LIFF → Add). Scopes: openid + profile.
# Set the LIFF Endpoint URL to your app origin (e.g. https://yourdomain).
# Leave blank to disable auto-login (the manual LINE button still works).
NEXT_PUBLIC_LIFF_ID=

# LINE Messaging API (https://developers.line.biz/console/) — channel type: Messaging API
# Used by notifyTournamentAdmins (Phase 7a). Leave blank to disable LINE push.
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# Messaging API channel secret — verifies the inbound webhook x-line-signature. Same channel as the token above.
LINE_MESSAGING_CHANNEL_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string
