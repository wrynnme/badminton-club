# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login (https://developers.line.biz/console/) — channel type: LINE Login
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback

# LINE Messaging API (https://developers.line.biz/console/) — channel type: Messaging API
# Used by notifyTournamentAdmins (Phase 7a). Leave blank to disable LINE push.
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# Messaging API channel secret — verifies the inbound webhook x-line-signature (club auto-billing). Same channel as the token above.
LINE_MESSAGING_CHANNEL_SECRET=

# Slip verification — DEPRECATED (platform-level keys removed).
# Provider config is now per-club: clubs.billing_verify_settings (mode/provider/branch_id)
# + club_billing_secrets.api_key. Set via the club settings UI (updateClubBillingVerifySettingsAction).
# SLIP_VERIFY_PROVIDER=         # DEPRECATED — no longer read by any code
# SLIP_VERIFY_API_KEY=          # DEPRECATED — no longer read by any code
# SLIP_VERIFY_SLIPOK_BRANCH_ID= # DEPRECATED — no longer read by any code

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string
