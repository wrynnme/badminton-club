# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login (https://developers.line.biz/console/) — channel type: LINE Login
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback

# LINE Messaging API (https://developers.line.biz/console/) — channel type: Messaging API
# Used by notifyTournamentAdmins (Phase 7a). Leave blank to disable LINE push.
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string
